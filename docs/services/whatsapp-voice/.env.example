# Microserviço de voz WhatsApp (Epic 7 / 7.1) — variáveis do SERVIÇO.
# O mesmo WACALLS_API_KEY deve ser configurado no Enriquece (Coolify).

# --- Auth ---
# Exigida em TODAS as rotas /api/* (header X-API-Key; ?apiKey= para o SSE).
# Gerar forte: openssl rand -hex 32
WACALLS_API_KEY=

# --- HTTP API (server-to-server) ---
WACALLS_HTTP_ADDR=:8080

# --- Rede / NAT (mídia WebRTC) ---
# IP público da VPS para NAT 1:1 (SetNAT1To1IPs). 'auto' tenta detectar.
WACALLS_PUBLIC_IP=auto
# Porta de mídia: UDP + fallback ICE-TCP no MESMO port (quando UDP inbound é
# bloqueado, o browser cai para TCP). Liberar no firewall (UDP e TCP).
WACALLS_UDP_PORT=3478

# --- Estado da sessão WhatsApp ---
WACALLS_DB_PATH=/data/wacalls.db

# --- Webhook por sessão (opcional p/ BI) ---
# Quando setado, o serviço POSTa o lifecycle da chamada (incl. recording_url no
# 'ended') para esta URL. Alternativa ao SSE para o pipeline server-side.
# WACALLS_WEBHOOK_URL=
# WACALLS_WEBHOOK_TIMEOUT_MS=5000
