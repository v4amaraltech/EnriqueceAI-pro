# ============================================
# Flux App — Variáveis de Ambiente
# ============================================
# Copie para .env.local e preencha os valores.
# Para produção, configure na Vercel Dashboard.
# ============================================

# ── Supabase ──
# Local: rode `npx supabase start` e copie as keys
# Produção: copie do dashboard do Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI (geração de mensagens via Claude) ──
ANTHROPIC_API_KEY=

# ── Google OAuth (Gmail + Calendar) ──
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/gmail

# ── Billing (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Lead Enrichment (Lemit) ──
LEMIT_API_URL=https://api.lemit.com.br/api/v1
LEMIT_API_TOKEN=

# ── Apollo.io (importação de leads) ──
# Crie em: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# ── Cron (autenticação dos jobs agendados) ──
CRON_SECRET=

# ── Monitoring (Sentry) ──
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Security (criptografia de tokens OAuth) ──
# Gere com: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
